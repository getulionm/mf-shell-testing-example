{
  "name": "mf-shell-testing-example",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal module-federation shell testing example",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:shell": "webpack serve --config apps/shell/webpack.config.ts",
    "dev:records": "webpack serve --config apps/records-remote/webpack.config.ts",
    "dev:tools": "webpack serve --config apps/tools-remote/webpack.config.ts",
    "dev": "concurrently -k -n shell,records,tools \"npm run dev:shell\" \"npm run dev:records\" \"npm run dev:tools\"",
    "build": "npm run build:shell && npm run build:records && npm run build:tools",
    "build:shell": "webpack --config apps/shell/webpack.config.ts",
    "build:records": "webpack --config apps/records-remote/webpack.config.ts",
    "build:tools": "webpack --config apps/tools-remote/webpack.config.ts",
    "test:unit": "vitest run tests/unit",
    "test:contract": "vitest run tests/contract",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test": "npm run test:unit && npm run test:contract && npm run test:integration && npm run test:e2e:smoke"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "concurrently": "^9.2.1",
    "css-loader": "^7.1.4",
    "html-webpack-plugin": "^5.6.7",
    "jsdom": "^29.1.1",
    "playwright": "^1.59.1",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  },
  "dependencies": {
    "@mf/fault-toggles": "0.1.0",
    "@mf/module-contracts": "0.1.0",
    "@mf/test-utils": "0.1.0"
  }
}
